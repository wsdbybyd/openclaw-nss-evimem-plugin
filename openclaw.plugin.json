{
  "id": "openclaw-nss-evimem-plugin",
  "name": "OpenClaw NSS-EviMem",
  "version": "0.1.0",
  "description": "Generic OpenClaw hook plugin for evidence capture, evidence-backed memory, and tool-governance decisions.",
  "enabledByDefault": false,
  "activation": {
    "onStartup": true,
    "onCapabilities": [
      "hook",
      "tool"
    ]
  },
  "contracts": {
    "tools": [
      "nss_evimem_promote_memory",
      "nss_evimem_retrieve_memory",
      "nss_evimem_guard_decision",
      "nss_evimem_import_pack"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  }
}
