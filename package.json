{
  "name": "openclaw-nss-evimem-plugin",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Generic OpenClaw plugin for NSS-EviMem evidence capture, evidence-backed memory, and guard decisions.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "case:cbsc-simon32-dl": "node cases/CBSC-V2-HARD-SIMON32-DL-SEARCH-002/run_openclaw_case.mjs",
    "case:cbsc-simon32-dl:evaluate": "node cases/CBSC-V2-HARD-SIMON32-DL-SEARCH-002/evaluate_case.mjs",
    "case:cbsc-simon32-dl:verify": "node cases/CBSC-V2-HARD-SIMON32-DL-SEARCH-002/verify_case.mjs",
    "case:cbsc-simon32-dl:all": "npm run case:cbsc-simon32-dl && npm run case:cbsc-simon32-dl:evaluate && npm run case:cbsc-simon32-dl:verify"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "typescript": "^5.4.0"
  }
}
